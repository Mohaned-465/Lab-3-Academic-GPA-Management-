CREATE TABLE semesters(
 id INT AUTO_INCREMENT PRIMARY KEY,
 label VARCHAR(20),
 is_active BOOLEAN DEFAULT 1
);

INSERT INTO semesters(label,is_active) VALUES ('S1',1);

CREATE TABLE courses(
 id INT AUTO_INCREMENT PRIMARY KEY,
 semester_id INT,
 name VARCHAR(100),
 credits INT
);

INSERT INTO courses(semester_id,name,credits) VALUES (1,'Math',3);

CREATE TABLE enrollments(
 student_id INT,
 semester_id INT
);

INSERT INTO enrollments VALUES (3,1);

CREATE TABLE grades(
 student_id INT,
 course_id INT,
 semester_id INT,
 professor_id INT,
 grade DECIMAL(3,1),
 UNIQUE(student_id,course_id,semester_id)
);

CREATE TABLE gpa_records(
 student_id INT,
 semester_id INT,
 gpa DECIMAL(4,2),
 UNIQUE(student_id,semester_id)
);
