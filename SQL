CREATE DATABASE gpa_db;
USE gpa_db;

CREATE TABLE users(
 id INT AUTO_INCREMENT PRIMARY KEY,
 name VARCHAR(100),
 email VARCHAR(100),
 password VARCHAR(255),
 role ENUM('admin','professor','student')
);

